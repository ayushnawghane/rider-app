# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_PHONE_OTP_FUNCTION_NAME=phone-otp-auth

# Google Maps
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Social Login — see docs/social_login_setup.md
# Apple "Services ID" + return URL (used by the web OAuth flow; native iOS uses the bundle id)
VITE_APPLE_CLIENT_ID=com.blinkcar.app.signin
VITE_APPLE_REDIRECT_URL=https://your-project.supabase.co/auth/v1/callback
# Google uses Supabase's web OAuth redirect, so it needs no client id in the app.
